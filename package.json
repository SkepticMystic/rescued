    "@better-auth/passkey": "^1.6.11",
    "@libpdf/core": "^0.3.6",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/sveltekit": "^10.53.1",
    "@unpic/svelte": "^1.0.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.11",
    "bits-ui": "^2.18.1",
    "drizzle-orm": "1.0.0-beta.22",
    "drizzle-zod": "^0.8.3",
    "marked": "^18.0.4",
    "mode-watcher": "^1.1.0",
    "pino": "^10.3.1",
    "qrcode-generator": "^2.0.4",
    "resend": "^6.12.3",
