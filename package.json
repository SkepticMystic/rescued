{
  "name": "app-starter-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "vp config",
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test",
    "test:ui": "vp test --ui",
    "test:run": "vp test run",
    "test:integration": "vp test --project=integration --passWithNoTests",
    "test:coverage": "vp test run --coverage",
    "knip": "knip",
    "scan:secrets": "docker run --rm -v \"$PWD:/pwd\" trufflesecurity/trufflehog:latest git file:///pwd --fail",
    "format": "prettier . --write --experimental-cli",
    "sonda": "SONDA=1 pnpm build",
    "check:slow": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"state_referenced_locally:ignore\"",
    "check": "svelte-kit sync && svelte-check --tsgo --incremental --tsconfig ./tsconfig.json --compiler-warnings \"state_referenced_locally:ignore\"",
    "SOURCE": "https://www.sveltepatterns.dev/how-to-access-svelte-specific-api-in-a-script",
    "_db": "vite-node --options.transformMode.ssr='/.*/' ./scripts/drizzle/kit.script.ts",
    "db:push": "pnpm _db push",
    "db:generate": "dotenvx run --env-file=.env.production -- pnpm _db generate",
    "db:check": "dotenvx run --env-file=.env.production -- pnpm _db check",
    "db:migrate": "pnpm _db migrate",
    "db:studio": "pnpm _db studio"
  },
  "dependencies": {
